{
  "name": "win-todo-reminder",
  "version": "1.0.0",
  "description": "Windows 桌面待办事项提醒软件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed"
  },
  "keywords": [
    "todo",
    "reminder",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.win-todo-reminder",
    "productName": "WinTodoReminder",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
